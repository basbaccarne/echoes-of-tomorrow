[Unit]
Description=Echoes of Tomorrow - Booth 3
After=network.target

[Service]
Type=simple
User=io
WorkingDirectory=/home/io/echoes-of-tomorrow/src_server
ExecStart=python3 /home/io/echoes-of-tomorrow/src_server/main.py --booth-id=3
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
